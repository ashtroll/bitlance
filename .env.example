# ─── Database ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bitlance
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/bitlance

# ─── JWT ────────────────────────────────────────
SECRET_KEY=replace-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── AI (add at least one) ──────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=gpt-4o

# ─── Platform ───────────────────────────────────
PLATFORM_FEE_PERCENT=5.0
SANDBOX_TIMEOUT_SECONDS=30
DEBUG=false

# ─── Frontend ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
